# --- Whop (optional) -------------------------------------------------------
# Leave these blank to run the fully-modeled demo: entries are recorded
# directly to the local ledger, no real charge. Fill them in to route entry
# payments through real Whop embedded checkout.

# Company API key — Whop dashboard → Developer → API keys
WHOP_API_KEY=

# The plan entries check out against (plan_...).
# Create a plan in the dashboard, or via client.plans.create.
WHOP_PLAN_ID=plan_xxxxxxxxxxxxx

# Webhook signing secret — set when you register the webhook endpoint.
# Whop's SDK reads this automatically for webhooks.unwrap().
WHOP_WEBHOOK_SECRET=

# Public base URL used to build the checkout return URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
